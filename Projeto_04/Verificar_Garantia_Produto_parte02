# Parte 02 – Verificar garantia do produto

# Objetivo: Criar um programa que:

# peça o nome do usuário, peça o produto, peça quantos meses de uso e informe se o produto ainda está na garantia

# Utilizei o print(), input(), int() e o if/else para indicar condição

nome = input("Qual seu nome? ")

produto = input("Digite o nome do produto: ")

meses = int(input("Quantos meses de uso tem o produto? "))

print()
print("Cliente:" , nome)
print("Produto:" , produto)

if meses <= 12:
    print("Seu produto está na garantia.")
else:
    print("Infelizmente a garantia do seu produto já acabou.")
